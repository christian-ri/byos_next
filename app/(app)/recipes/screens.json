	"calendar-apple": {
		"title": "Calendar (Apple)",
		"published": true,
		"createdAt": "2026-03-29T00:00:00Z",
		"updatedAt": "2026-03-30T00:00:00Z",
		"description": "Apple Calendar recipe styled after the official TRMNL plugin with default, week, and month layouts.",
		"componentPath": "./screens/calendar-apple",
		"hasDataFetch": true,
		"props": {
			"providerLabel": "Apple",
			"title": "Apple Calendar",
			"subtitle": "Personal Calendar",
			"timeZone": "America/New_York",
			"updatedAt": "Mar 29, 11:40 PM",
			"note": "Preview - your device will show actual data once an ICS feed is configured.",
			"eventLayout": "month",
			"includeDescription": true,
			"includeEventTime": true,
			"firstDay": 1,
			"defaultDays": [],
			"weekDays": [],
			"monthWeeks": [],
			"monthLabel": "March 2026"
		},
		"params": {
			"icsUrl": {
				"type": "multiline",
				"label": "ICS URL(s)",
				"description": "Apple/iCloud published ICS URL. Multiple feeds may be entered on separate lines. Replace webcal:// with https://.",
				"default": "",
				"placeholder": "https://example.com/calendar.ics"
			},
			"calendarName": {
				"type": "string",
				"label": "Calendar Name",
				"description": "Subtitle shown below the plugin title.",
				"default": "Personal Calendar"
			},
			"headers": {
				"type": "multiline",
				"label": "Headers",
				"description": "Optional request headers in key=value or Header: Value format, one per line.",
				"default": ""
			},
			"timezone": {
				"type": "string",
				"label": "Time Zone",
				"description": "IANA time zone used for display.",
				"default": "America/New_York"
			},
			"eventLayout": {
				"type": "string",
				"label": "Layout",
				"description": "Use default, week, or month.",
				"default": "month"
			},
			"timeFormat": {
				"type": "string",
				"label": "Time Format",
				"description": "Use 12h or 24h.",
				"default": "12h"
			},
			"includeDescription": {
				"type": "string",
				"label": "Include Description",
				"description": "Use yes or no. Most visible in the default layout.",
				"default": "yes"
			},
			"includeEventTime": {
				"type": "string",
				"label": "Include Event Time",
				"description": "Use yes or no.",
				"default": "yes"
			},
			"firstDay": {
				"type": "string",
				"label": "First Day of Week",
				"description": "Applies to the month layout. Use sunday or monday.",
				"default": "sunday"
			},
			"ignoredPhrases": {
				"type": "multiline",
				"label": "Ignored Phrases",
				"description": "Events whose title or description includes these phrases will be ignored. One phrase per line.",
				"default": ""
			},
			"maxEventsPerDay": {
				"type": "number",
				"label": "Max Events Per Day",
				"description": "Caps visible events inside each day cell.",
				"default": 4
			}
		},
		"tags": ["calendar", "ics", "apple", "month-view", "week-view"],
		"author": {
			"name": "TRMNL",
			"github": "usetrmnl"
		},
		"renderSettings": {},
		"version": "0.1.0",
		"category": "trmnl-imports"
	},
